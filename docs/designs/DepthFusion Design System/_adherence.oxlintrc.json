{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/data/**",
              "components/forms/**",
              "components/navigation/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Inter Tight|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Inter Tight, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:public|internal|confidential|restricted|source)$/]",
        "message": "<Badge> variant must be one of 'public' | 'internal' | 'confidential' | 'restricted' | 'source'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|danger|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'danger' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='LogoMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|plate|mark|flat|animation|className|key|ref|className|style|children)$/]",
        "message": "<LogoMark> doesn't accept that prop. Declared props: size, plate, mark, flat, animation, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='NodeChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|children|key|ref|className|style|children)$/]",
        "message": "<NodeChip> doesn't accept that prop. Declared props: type, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='NodeChip'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:doc|concept|decision)$/]",
        "message": "<NodeChip> type must be one of 'doc' | 'concept' | 'decision'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Radio'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<Radio> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResultData'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|cls|source|snippet|score|date|loc|key|ref|className|style|children)$/]",
        "message": "<ResultData> doesn't accept that prop. Declared props: title, cls, source, snippet, score, date, loc."
      },
      {
        "selector": "JSXOpeningElement[name.name='ResultData'] > JSXAttribute[name.name='cls'] > Literal[value!=/^(?:public|internal|confidential|restricted)$/]",
        "message": "<ResultData> cls must be one of 'public' | 'internal' | 'confidential' | 'restricted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|value|onChange|className|key|ref|className|style|children)$/]",
        "message": "<Tabs> doesn't accept that prop. Declared props: tabs, value, onChange, className."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
