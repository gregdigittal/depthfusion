# DepthFusion V2 — Environment Variables Reference
#
# Copy this file to ~/.claude/depthfusion.env and fill in real values.
# The installer writes this file automatically; edit to customise.
#
# NEVER commit a filled-in copy of this file — it contains secrets.
# The .gitignore entry for *.env and depthfusion.env protects against
# accidental commits when the file lives in the project root.
#
# Sections:
#   [REQUIRED]  Must be set; server refuses to start without them.
#   [OIDC]      Required for V2 identity (Entra ID / OIDC).
#   [AUTH]      Legacy and inter-service auth.
#   [MODE]      Installation mode and tier selection.
#   [LLM]       Backend routing for embedding, reranking, extraction.
#   [API]       FastAPI server binding and transport.
#   [STORAGE]   Data directories and corpus backends.
#   [FEATURES]  Feature flags (graph, fusion, metrics, etc.).
#   [SYNC]      Sync v2 — ACL-aware replication.
#   [ADVANCED]  Rarely changed tuning knobs.

# ===========================================================================
# [OIDC] — Entra ID / OIDC identity (V2 required)
# ===========================================================================

# Azure AD application (client) ID registered for DepthFusion.
# Obtain from: Azure Portal → App registrations → your app → Application ID.
DEPTHFUSION_OIDC_CLIENT_ID=

# Azure AD directory (tenant) ID.
# Obtain from: Azure Portal → App registrations → your app → Directory (tenant) ID.
DEPTHFUSION_OIDC_TENANT_ID=

# OAuth2 scope requested during sign-in.
# Default: https://graph.microsoft.com/.default (required for SharePoint access).
# Format: space-separated scope strings.
DEPTHFUSION_OIDC_SCOPE=https://graph.microsoft.com/.default

# OIDC issuer URL — must match the 'iss' claim in tokens.
# Default computed from TENANT_ID: https://login.microsoftonline.com/<TENANT_ID>/v2.0
# Override only if using a non-Entra OIDC provider (e.g. Keycloak, Auth0).
DEPTHFUSION_OIDC_ISSUER=

# Token audience — must match the 'aud' claim in tokens issued by Entra.
# Typically the application ID URI or the client ID.
DEPTHFUSION_OIDC_AUDIENCE=

# OAuth2 redirect URI registered in the app's Redirect URIs list.
# Must match exactly; used during the authorization-code + PKCE flow.
# Example: http://localhost:8400/callback
DEPTHFUSION_OIDC_REDIRECT_URI=http://localhost:8400/callback

# JWKS endpoint URL — used to validate JWT signatures.
# Default computed from TENANT_ID: https://login.microsoftonline.com/<TENANT_ID>/discovery/v2.0/keys
# Override if using a custom OIDC provider.
DEPTHFUSION_JWKS_URI=

# ===========================================================================
# [AUTH] — API token and legacy auth
# ===========================================================================

# Bearer token for the DepthFusion REST API (V1 / legacy mode).
# Required when DEPTHFUSION_API_PUBLIC=1 or DEPTHFUSION_V2_LEGACY_AUTH=1.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DEPTHFUSION_API_TOKEN=

# MCP HTTP server bearer token (if DEPTHFUSION_MCP_PUBLIC=1).
DEPTHFUSION_MCP_TOKEN=

# Query API key — permits read-only access to /query/* endpoints.
# Required when DEPTHFUSION_API_PUBLIC=1.
DEPTHFUSION_QUERY_API_KEY=

# Set to 1 to accept the legacy API-token in V2 mode.
# Tokens are mapped to a flagged legacy principal; a deprecation warning is logged.
# Remove once all clients migrate to OIDC.
DEPTHFUSION_V2_LEGACY_AUTH=0

# ===========================================================================
# [LLM] — LLM backend routing
# ===========================================================================

# Anthropic API key used by DepthFusion's own LLM calls (reranking,
# extraction, summarisation). DISTINCT from ANTHROPIC_API_KEY used by
# Claude Code itself — keeping them separate avoids billing surprises.
# Required for vps-cpu and vps-gpu modes.
DEPTHFUSION_API_KEY=

# Embedding backend: null | local | haiku
# null   — no semantic embeddings (BM25 only)
# local  — sentence-transformers on-box (vps-gpu)
# haiku  — Anthropic Haiku for embeddings (vps-cpu)
DEPTHFUSION_EMBEDDING_BACKEND=null

# Local embedding model name (sentence-transformers, used when EMBEDDING_BACKEND=local).
DEPTHFUSION_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Reranker backend: null | haiku | gemma
DEPTHFUSION_RERANKER_BACKEND=null

# Structured extractor backend (entity/decision extraction): null | haiku | gemma
DEPTHFUSION_EXTRACTOR_BACKEND=null

# Summariser backend: null | haiku | gemma
DEPTHFUSION_SUMMARISER_BACKEND=null

# LLM linker backend (graph entity linking): null | haiku | gemma
DEPTHFUSION_LINKER_BACKEND=null

# Decision extractor backend: null | haiku | gemma
DEPTHFUSION_DECISION_EXTRACTOR_BACKEND=null

# Gemma vLLM endpoint URL (vps-gpu only).
# Example: http://127.0.0.1:8000
DEPTHFUSION_GEMMA_URL=http://127.0.0.1:8000

# Gemma model name for the vLLM endpoint.
DEPTHFUSION_GEMMA_MODEL=google/gemma-3-4b-it

# OpenRouter API key (used as Codex-side reviewer and fallback LLM).
OPENROUTER_API_KEY=

# ===========================================================================
# [MODE] — Installation mode and tier
# ===========================================================================

# Installation mode: local | vps-cpu | vps-gpu | mac-mlx
DEPTHFUSION_MODE=local

# Corpus size threshold for Tier 2 promotion (ChromaDB + vector search).
# When session count crosses this, the tier manager promotes automatically.
DEPTHFUSION_TIER_THRESHOLD=500

# Set to 1 to allow automatic tier promotion.
DEPTHFUSION_TIER_AUTOPROMOTE=0

# ===========================================================================
# [API] — FastAPI server binding and transport
# ===========================================================================

# FastAPI server port.
DEPTHFUSION_API_PORT=7300

# Set to 1 to bind the REST API to 0.0.0.0 instead of 127.0.0.1.
# REQUIRES DEPTHFUSION_API_TOKEN and DEPTHFUSION_QUERY_API_KEY to be set.
# Use only behind a reverse proxy (nginx / Tailscale) with TLS termination.
DEPTHFUSION_API_PUBLIC=0

# Set to 1 to spawn a second listener on the Tailscale interface.
# Requires tailscale CLI and DEPTHFUSION_API_TOKEN.
DEPTHFUSION_API_TAILSCALE=0

# MCP server port (HTTP transport).
DEPTHFUSION_MCP_PORT=7301

# Set to 1 to bind MCP HTTP server publicly. Requires DEPTHFUSION_MCP_TOKEN.
DEPTHFUSION_MCP_PUBLIC=0

# Redis URL for pub/sub bus (optional; defaults to loopback).
# If set, must bind 127.0.0.1 only per infra-exposure policy.
DEPTHFUSION_REDIS_URL=redis://127.0.0.1:6379/0

# RLM (recursive LLM) service port.
DEPTHFUSION_RLM_PORT=7302

# ===========================================================================
# [STORAGE] — Data directories and storage backends
# ===========================================================================

# Graph storage backend: json | sqlite | chroma
# json   — local mode (no dependencies)
# sqlite — VPS Tier 1
# chroma — Tier 2 (ChromaDB required)
# (Set automatically by the installer based on DEPTHFUSION_MODE.)

# Context bus backend: memory | file
DEPTHFUSION_BUS_BACKEND=memory

# Directory for file-bus messages (if BUS_BACKEND=file).
DEPTHFUSION_BUS_FILE_DIR=~/.claude/depthfusion/bus

# Number of days before a discovery or session file is pruned.
DEPTHFUSION_PRUNE_AGE_DAYS=90

# ===========================================================================
# [FEATURES] — Feature flags
# ===========================================================================

# Enable knowledge graph entity extraction and traversal.
DEPTHFUSION_GRAPH_ENABLED=true

# Enable Haiku-powered reranking (requires DEPTHFUSION_API_KEY).
DEPTHFUSION_HAIKU_ENABLED=false

# Enable HNSW approximate-nearest-neighbour vector search.
DEPTHFUSION_HNSW_ENABLED=false

# Enable vector search step in hybrid recall pipeline.
DEPTHFUSION_VECTOR_SEARCH_ENABLED=false

# Enable BM25 + vector RRF fusion scoring (Tier 2+).
DEPTHFUSION_FUSION_GATES_ENABLED=false

# Enable full-text search index (SQLite FTS5).
DEPTHFUSION_FTS_ENABLED=false

# Enable structured metrics collection (JSONL).
# Set to 1 to collect; performance overhead is minimal.
DEPTHFUSION_METRICS_ENABLED=0

# Enable embedding-based discovery deduplication.
DEPTHFUSION_DEDUP_ENABLED=false

# Cosine-similarity threshold for discovery dedup (0.0–1.0).
DEPTHFUSION_DEDUP_THRESHOLD=0.92

# Enable context pub/sub router.
DEPTHFUSION_ROUTER_ENABLED=false

# Enable cognitive-scoring layer (ambient session analysis).
DEPTHFUSION_COGNITIVE_SCORING=false

# Enable autonomic agent features.
DEPTHFUSION_AUTONOMIC=false

# Enable contradiction detection engine.
DEPTHFUSION_CONTRADICTION_ENGINE=false

# Enable decision extractor.
DEPTHFUSION_DECISION_EXTRACTOR_ENABLED=false

# Enable RLM task budget enforcement.
DEPTHFUSION_RLM_TASK_BUDGET_ENABLED=false

# Enable context blend mode: weighted | rrf | flat
DEPTHFUSION_BLEND_MODE=weighted

# ===========================================================================
# [SYNC] — Sync v2 — ACL-aware replication (V2)
# ===========================================================================

# IMPORTANT: sync.sh (V1 wholesale rsync) is retired in V2. Setting
# DEPTHFUSION_SYNC_OVERRIDE=1 re-enables it only for emergency read-only use.
# Do not set this in production. See docs/decisions/sync-v2-design.md.
# DEPTHFUSION_SYNC_OVERRIDE=1

# ===========================================================================
# [ADVANCED] — Tuning knobs (rarely changed)
# ===========================================================================

# Minimum graph entity confidence for persistence.
DEPTHFUSION_GRAPH_MIN_CONFIDENCE=0.7

# JSONL path for LLM backend fallback events.
DEPTHFUSION_BACKEND_FALLBACK_LOG=~/.claude/depthfusion-fallback.jsonl

# Default snippet length returned by /recall (characters).
DEPTHFUSION_AUTO_RECALL_SNIPPET_LEN=1500

# Default top-K results for auto-recall on session start.
DEPTHFUSION_AUTO_RECALL_TOP_K=5

# Ambient session analysis: tools to skip (comma-separated tool names).
DEPTHFUSION_AMBIENT_SKIP_TOOLS=

# Admission threshold for context routing (0.0–1.0).
DEPTHFUSION_ADMISSION_THRESHOLD=0.5

# Memory consolidation interval (minutes).
DEPTHFUSION_CONSOLIDATION_INTERVAL_MINUTES=60

# Project slug for this instance (used in discovery file naming).
DEPTHFUSION_PROJECT=

# Venv path (used by hooks to locate the correct Python interpreter).
DEPTHFUSION_VENV_PATH=

# ===========================================================================
# [INTEGRATIONS] — External integrations
# ===========================================================================

# SkillForge API endpoint and key (for SkillForge ↔ DepthFusion bridge).
DEPTHFUSION_SKILLFORGE_API_URL=
DEPTHFUSION_SKILLFORGE_API_KEY=
