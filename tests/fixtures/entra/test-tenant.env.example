# Example Entra ID test-tenant configuration for the depthfusion.identity package.
# Copy to a real .env (kept out of git) and fill in values for live testing.
# Unit tests do NOT require these — they use the mock JWKS fixture instead.

# Application (client) id of the public client registered in Entra ID.
DEPTHFUSION_OIDC_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Directory (tenant) id.
DEPTHFUSION_OIDC_TENANT_ID=11111111-1111-1111-1111-111111111111

# Redirect URI registered for the authorization-code (PKCE) flow.
DEPTHFUSION_OIDC_REDIRECT_URI=http://localhost:8765/callback

# Space-delimited scopes.
DEPTHFUSION_OIDC_SCOPE=openid profile offline_access

# JWKS endpoint (the v2.0 keys document for the tenant).
DEPTHFUSION_JWKS_URI=https://login.microsoftonline.com/11111111-1111-1111-1111-111111111111/discovery/v2.0/keys

# Expected token issuer and audience (override the derived defaults if needed).
DEPTHFUSION_OIDC_ISSUER=https://login.microsoftonline.com/11111111-1111-1111-1111-111111111111/v2.0
DEPTHFUSION_OIDC_AUDIENCE=00000000-0000-0000-0000-000000000000
