# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environment
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Test / coverage artifacts
.pytest_cache/
.coverage
.coverage.*
coverage.xml
coverage.json
htmlcov/
.tox/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# ruff
.ruff_cache/

# Session / runtime state
*.tmp
*.log
*.jsonl

# Ingestion quarantine — runtime artifacts, not source
data/quarantine/
# Allow checked-in fixture files (top-level and subdirectories)
!tests/fixtures/*.jsonl
!tests/fixtures/ciqs_cat_d/*.jsonl

# Telemetry runtime DB (model_telemetry.db) — root-level only
/telemetry/
*.db

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
.worktrees/

# Local tooling — Claude Code, agent-hub, Codex
.claude/*
!.claude/workflows/
!.claude/v2-routing.yaml
.pm/
.rollback/
.codex
text.txt
.remember/

# Private VPS connect scripts (contain credentials — never commit)
scripts/connect-vps.sh
scripts/connect-vps.ps1

# Test tenant environment files (contain secrets — never commit)
tests/fixtures/entra/test-tenant.env
!tests/fixtures/entra/test-tenant.env.example

# Local env overrides (may contain runtime secrets — never commit)
.env
