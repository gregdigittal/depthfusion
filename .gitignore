# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environment
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Test / coverage artifacts
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# ruff
.ruff_cache/

# Session / runtime state
*.tmp
*.log
*.jsonl
# Allow checked-in fixture files (top-level and subdirectories)
!tests/fixtures/*.jsonl
!tests/fixtures/ciqs_cat_d/*.jsonl

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
.worktrees/
