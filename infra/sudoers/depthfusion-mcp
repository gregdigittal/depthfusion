# Passwordless sudo for depthfusion-mcp service management
# cp of the unit file is intentionally excluded: source path is user-writable,
# allowing privilege escalation via arbitrary ExecStart. Copy manually with sudo.
gregmorris ALL=(ALL) NOPASSWD: /usr/bin/systemctl start depthfusion-mcp
gregmorris ALL=(ALL) NOPASSWD: /usr/bin/systemctl stop depthfusion-mcp
gregmorris ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart depthfusion-mcp
gregmorris ALL=(ALL) NOPASSWD: /usr/bin/systemctl reload depthfusion-mcp
gregmorris ALL=(ALL) NOPASSWD: /usr/bin/systemctl enable depthfusion-mcp
gregmorris ALL=(ALL) NOPASSWD: /usr/bin/systemctl disable depthfusion-mcp
gregmorris ALL=(ALL) NOPASSWD: /usr/bin/systemctl daemon-reload
